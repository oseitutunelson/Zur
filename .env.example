# Supabase — copy this file to `.env.local` and fill in your project values.
# Find these in your Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the browser: Row-Level Security enforces access.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key

# Minutes of inactivity before an admin is automatically logged out.
VITE_ADMIN_IDLE_MINUTES=20
